<?xml version="1.0" encoding="utf-8"?>
<!-- Settings Fragment with Sub-tabs (#83 requirement) -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:orientation="vertical">

    <!-- Sub-tabs Header -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:id="@+id/subtabsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tabGeneral"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_settings_subtab"
                android:paddingHorizontal="20dp"
                android:paddingVertical="10dp"
                android:text="General"
                android:textColor="@color/text_light"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tabPopUp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_settings_subtab"
                android:paddingHorizontal="20dp"
                android:paddingVertical="10dp"
                android:text="Pop Up"
                android:textColor="@color/text_muted"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tabNotification"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_settings_subtab"
                android:paddingHorizontal="20dp"
                android:paddingVertical="10dp"
                android:text="Notification"
                android:textColor="@color/text_muted"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tabAdvanced"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_settings_subtab"
                android:paddingHorizontal="20dp"
                android:paddingVertical="10dp"
                android:text="Advanced"
                android:textColor="@color/text_muted"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Content Area -->
    <FrameLayout
        android:id="@+id/settingsContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="20dp"
        android:paddingBottom="20dp">

        <!-- General Panel -->
        <ScrollView
            android:id="@+id/panelGeneral"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Enable OrderMate In Clover's Register Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_settings_card_glass"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enable OrderMate In Clover's Register"
                        android:textColor="@color/text_light"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="16dp"
                        android:text="Choose how OrderMate integrates with Clover Register"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />

                    <!-- Coming Soon Toggle (disabled) - with container -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_toggle_option_container"
                        android:padding="14dp"
                        android:alpha="0.6"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Use OrderMate Register Instead Of Clover Register"
                                android:textColor="@color/text_light"
                                android:textSize="13sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_coming_soon_badge"
                                android:text="🚀 Coming Soon"
                                android:textColor="@color/orange_accent"
                                android:textSize="10sp" />

                        </LinearLayout>

                        <Switch
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            android:enabled="false"
                            android:thumb="@drawable/bg_toggle_thumb"
                            android:track="@drawable/bg_toggle_track" />

                    </LinearLayout>

                    <!-- Use OrderMate In Clover's Register Toggle - with container -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_toggle_option_container"
                        android:padding="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Use OrderMate In Clover's Register"
                            android:textColor="@color/text_light"
                            android:textSize="13sp" />

                        <Switch
                            android:id="@+id/switchUseInCloverRegister"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:thumb="@drawable/bg_toggle_thumb"
                            android:track="@drawable/bg_toggle_track" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- Pop Up Panel -->
        <ScrollView
            android:id="@+id/panelPopUp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Pop Up Editor Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_settings_card_glass"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Centered title and subtitle -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="OrderMate Pop Up Editor"
                        android:textColor="@color/text_light"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="16dp"
                        android:gravity="center"
                        android:text="Add &amp; Edit Sections That Appear In the OrderMate Editor"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />

                    <!-- Widget List Container -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_widget_list_container"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:minHeight="200dp">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/widgetRecyclerView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            tools:itemCount="4"
                            tools:listitem="@layout/item_widget_editor" />

                    </LinearLayout>

                    <!-- Add Widget Button -->
                    <LinearLayout
                        android:id="@+id/btnAddWidget"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_add_widget_button"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_add"
                            app:tint="@color/text_muted" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Add Widget"
                            android:textColor="@color/text_muted"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- Notification Panel -->
        <ScrollView
            android:id="@+id/panelNotification"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Notification Templates Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_settings_card_glass"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Notification Templates"
                        android:textColor="@color/text_light"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="16dp"
                        android:text="Create text templates for notification popups. Used for email or SMS. Available in notification popup dropdown."
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />

                    <!-- Template List -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/templateRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        tools:itemCount="2"
                        tools:listitem="@layout/item_notification_template" />

                    <!-- Add Template Button -->
                    <LinearLayout
                        android:id="@+id/btnAddTemplate"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_add_widget_button"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_add"
                            app:tint="@color/text_muted" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Add Template"
                            android:textColor="@color/text_muted"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- Advanced Panel -->
        <ScrollView
            android:id="@+id/panelAdvanced"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Scheduled Order Notifications Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_settings_card_glass"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Scheduled Order Notifications"
                        android:textColor="@color/text_light"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="16dp"
                        android:text="When to receive notifications for scheduled orders"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />

                    <!-- Input Row with days AND minutes -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input_row_container"
                        android:padding="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/inputNotificationDays"
                            android:layout_width="50dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_settings_input"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="2"
                            android:text="3"
                            android:textColor="@color/text_light"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="days"
                            android:textColor="@color/text_light"
                            android:textSize="13sp" />

                        <EditText
                            android:id="@+id/inputNotificationMinutes"
                            android:layout_width="50dp"
                            android:layout_height="36dp"
                            android:layout_marginStart="12dp"
                            android:background="@drawable/bg_settings_input"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="3"
                            android:text="0"
                            android:textColor="@color/text_light"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="minutes before"
                            android:textColor="@color/text_light"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Receipt Settings Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_settings_card_glass"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Receipt Settings"
                        android:textColor="@color/text_light"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="16dp"
                        android:text="Print kitchen receipt before due date/time"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />

                    <!-- Input Row with days AND minutes -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input_row_container"
                        android:padding="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/inputReceiptDays"
                            android:layout_width="50dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_settings_input"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="2"
                            android:text="0"
                            android:textColor="@color/text_light"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="days"
                            android:textColor="@color/text_light"
                            android:textSize="13sp" />

                        <EditText
                            android:id="@+id/inputReceiptMinutes"
                            android:layout_width="50dp"
                            android:layout_height="36dp"
                            android:layout_marginStart="12dp"
                            android:background="@drawable/bg_settings_input"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="3"
                            android:text="60"
                            android:textColor="@color/text_light"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="minutes before"
                            android:textColor="@color/text_light"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </ScrollView>

    </FrameLayout>

</LinearLayout>
