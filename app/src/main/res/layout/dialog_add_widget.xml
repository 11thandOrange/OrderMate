<?xml version="1.0" encoding="utf-8"?>
<!-- Add Widget Dialog - styled like filter modal (#36) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog"
    android:padding="24dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/dialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Widget"
            android:textColor="@color/text_light"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"
            android:paddingBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select widget type to add"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:paddingBottom="16dp"/>

        <!-- Header bottom border -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1AFFFFFF"/>
    </LinearLayout>

    <!-- Widget Type Options - Each option on its own row -->
    <LinearLayout
        android:id="@+id/widgetTypeContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Calendar Option -->
        <LinearLayout
            android:id="@+id/optionCalendar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_filter_option"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginBottom="8dp">

            <!-- (#77) Color code widget icon: Calendar = Blue #64B5F6 -->
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_calendar"
                app:tint="#64B5F6"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calendar"
                    android:textColor="@color/text_light"
                    android:textSize="15sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Due dates, pick-up dates, deadlines"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Single Select Option -->
        <LinearLayout
            android:id="@+id/optionSingleSelect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_filter_option"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginBottom="8dp">

            <!-- (#77) Color code widget icon: Single Select = Purple #CE93D8 -->
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_check_box"
                app:tint="#CE93D8"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Single Select"
                    android:textColor="@color/text_light"
                    android:textSize="15sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select one note per item"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Multi Select Option -->
        <LinearLayout
            android:id="@+id/optionMultiSelect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_filter_option"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginBottom="8dp">

            <!-- (#77) Color code widget icon: Multi Select = Green #81C784, double checkmark -->
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_check_double"
                app:tint="#81C784"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Multi Select"
                    android:textColor="@color/text_light"
                    android:textSize="15sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select multiple notes per item"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Text Box Option -->
        <LinearLayout
            android:id="@+id/optionTextBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_filter_option"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp">

            <!-- (#77) Color code widget icon: Text Box = Brown #A1887F -->
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_text_format"
                app:tint="#A1887F"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Text Box"
                    android:textColor="@color/text_light"
                    android:textSize="15sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Descriptions, details, reminders"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Cancel Button -->
    <TextView
        android:id="@+id/btnCancel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="Cancel"
        android:textColor="@color/text_muted"
        android:textSize="14sp"
        android:paddingVertical="12dp"/>

</LinearLayout>
