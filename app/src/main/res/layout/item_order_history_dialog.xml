<?xml version="1.0" encoding="utf-8"?>
<!-- Order History Dialog Item - includes full message body for notifications (#58) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="top"
    android:paddingVertical="12dp">

    <!-- History Icon Container -->
    <FrameLayout
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_history_icon">

        <ImageView
            android:id="@+id/historyIcon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_history"
            app:tint="@color/text_muted"
            android:contentDescription="@string/history_event" />
    </FrameLayout>

    <!-- History Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/historyTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Event Title"
            android:textColor="@color/text_light"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/historyDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="March 15, 2026 • 9:00 AM"
            android:textColor="@color/text_muted"
            android:textSize="12sp" />

        <!-- Message body for notifications (#58) -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/historyMessageBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:padding="12dp"
            android:background="@drawable/bg_note_chip"
            android:textColor="@color/text_light"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.3"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
