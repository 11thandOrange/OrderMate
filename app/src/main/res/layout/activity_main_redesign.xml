<?xml version="1.0" encoding="utf-8"?>
<!-- iOS-style main layout with side navigation (#80 requirement) -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_purple"
    tools:context=".activities.MainActivity">

    <!-- Side Navigation Bar -->
    <LinearLayout
        android:id="@+id/sideNav"
        android:layout_width="72dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingVertical="20dp"
        android:paddingHorizontal="12dp"
        android:background="@color/side_nav_background"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Logo -->
        <FrameLayout
            android:id="@+id/navLogo"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/bg_nav_logo">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="OM"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </FrameLayout>

        <!-- Nav Items Container -->
        <LinearLayout
            android:id="@+id/navItemsContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- List Nav Item -->
            <FrameLayout
                android:id="@+id/navList"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_nav_item_active"
                android:clickable="true"
                android:focusable="true">
                
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_nav_list"
                    app:tint="@color/text_light"/>
                
                <!-- Active indicator -->
                <View
                    android:id="@+id/navListIndicator"
                    android:layout_width="4dp"
                    android:layout_height="24dp"
                    android:layout_gravity="start|center_vertical"
                    android:layout_marginStart="-12dp"
                    android:background="@drawable/bg_nav_indicator"/>
            </FrameLayout>

            <!-- Calendar Nav Item -->
            <FrameLayout
                android:id="@+id/navCalendar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_nav_item"
                android:clickable="true"
                android:focusable="true">
                
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_nav_calendar"
                    app:tint="@color/text_muted"/>
                
                <View
                    android:id="@+id/navCalendarIndicator"
                    android:layout_width="4dp"
                    android:layout_height="24dp"
                    android:layout_gravity="start|center_vertical"
                    android:layout_marginStart="-12dp"
                    android:background="@drawable/bg_nav_indicator"
                    android:visibility="gone"/>
            </FrameLayout>

            <!-- Settings Nav Item -->
            <FrameLayout
                android:id="@+id/navSettings"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_nav_item"
                android:clickable="true"
                android:focusable="true">
                
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_nav_settings"
                    app:tint="@color/text_muted"/>
                
                <View
                    android:id="@+id/navSettingsIndicator"
                    android:layout_width="4dp"
                    android:layout_height="24dp"
                    android:layout_gravity="start|center_vertical"
                    android:layout_marginStart="-12dp"
                    android:background="@drawable/bg_nav_indicator"
                    android:visibility="gone"/>
            </FrameLayout>

        </LinearLayout>

        <!-- Profile Avatar at bottom -->
        <FrameLayout
            android:id="@+id/navProfile"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_nav_profile"
            android:clickable="true"
            android:focusable="true">
            
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_nav_user"
                app:tint="@color/white"/>
        </FrameLayout>

    </LinearLayout>

    <!-- Main Content Area -->
    <FrameLayout
        android:id="@+id/mainContent"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        app:layout_constraintStart_toEndOf="@id/sideNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/nav_host_fragment"
            android:name="androidx.navigation.fragment.NavHostFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:navGraph="@navigation/nav_graph"
            app:defaultNavHost="true"/>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
