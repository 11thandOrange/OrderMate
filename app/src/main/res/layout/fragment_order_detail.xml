<?xml version="1.0" encoding="utf-8"?>
<!-- Order Detail Tab - matches HTML .order-detail-tab (#87) -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    tools:context=".fragment.orderDetail.OrderDetailFragment">

    <!-- Top Header Bar - matches HTML .order-detail-header -->
    <!-- height: 70px, background: rgba(0,0,0,0.1), border-bottom: 1px solid rgba(255,255,255,0.1) -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:background="@color/header_background"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Back Button - matches HTML .back-btn -->
        <!-- 40x40, border-radius: 12px, background: rgba(255,255,255,0.15) -->
        <ImageView
            android:id="@+id/backButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_button_glass"
            android:padding="10dp"
            android:src="@drawable/ic_back"
            app:tint="@color/text_light"
            android:contentDescription="@string/back" />

        <!-- Order ID Title - matches HTML .order-detail-title -->
        <!-- flex: 1, font-size: 18px, font-weight: 600, color: text-light -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/orderId"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="@string/dummy_heading_dashboard"
            android:textColor="@color/text_light"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Action Buttons Container - matches HTML .order-detail-actions -->
        <!-- gap: 12px -->
        <LinearLayout
            android:id="@+id/actionButtonsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Add Payment Button - matches HTML .order-action-btn.secondary -->
            <!-- background: rgba(255,255,255,0.15), padding: 10px 16px, border-radius: 12px -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/addPayment"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="12dp"
                android:backgroundTint="@color/glass_background"
                android:text="@string/add_payment"
                android:textSize="13sp"
                android:textColor="@color/text_light"
                android:paddingHorizontal="16dp"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_cash"
                app:iconTint="@color/text_light"
                app:iconSize="16dp"
                app:iconPadding="8dp" />

            <!-- Re-Open Button - matches HTML .order-action-btn.secondary -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/reOpenButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="12dp"
                android:backgroundTint="@color/glass_background"
                android:text="@string/re_open"
                android:textSize="13sp"
                android:textColor="@color/text_light"
                android:paddingHorizontal="16dp"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_refresh"
                app:iconTint="@color/text_light"
                app:iconSize="16dp"
                app:iconPadding="8dp" />

            <!-- Send Notification Button - matches HTML .order-action-btn.primary -->
            <!-- background: #FF9F43 (orange-accent) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/sendNotificationButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="12dp"
                android:backgroundTint="@color/orange_accent"
                android:text="@string/send_notification"
                android:textSize="13sp"
                android:textColor="@color/white"
                android:paddingHorizontal="16dp"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_notification"
                app:iconTint="@color/white"
                app:iconSize="16dp"
                app:iconPadding="8dp" />

            <!-- Delete Button - matches HTML .order-action-btn.danger -->
            <!-- background: #ea2c2f (unpaid-status-color) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/deleteButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:backgroundTint="@color/unpaid_status_color"
                android:text="@string/delete_order"
                android:textSize="13sp"
                android:textColor="@color/white"
                android:paddingHorizontal="16dp"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_delete"
                app:iconTint="@color/white"
                app:iconSize="16dp"
                app:iconPadding="8dp" />
        </LinearLayout>

        <!-- Hidden views for backward compatibility -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/syncingText"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/syncButton"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/merchantName"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/reIssueReceiptButton"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />
    </LinearLayout>
    
    <!-- Header border bottom - matches HTML border-bottom: 1px solid rgba(255,255,255,0.1) -->
    <View
        android:id="@+id/headerBorder"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/nav_border"
        app:layout_constraintTop_toBottomOf="@id/topBar" />

    <!-- Main Content Area - matches HTML .order-detail-content -->
    <!-- padding: 24px -->
    <LinearLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:padding="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerBorder">

        <!-- Left Column: Items Card - matches HTML .order-detail-main -->
        <!-- grid-template-columns: 1fr 380px, gap: 24px -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/orderDetails"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="24dp">

            <!-- Items Card - matches HTML .detail-card -->
            <!-- background: rgba(255,255,255,0.15), border-radius: 16px, border: 1px solid rgba(255,255,255,0.1) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/itemsCard"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardBackgroundColor="@color/glass_background"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/nav_border"
                app:strokeWidth="1dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- Card Header - matches HTML .detail-card-header -->
                    <LinearLayout
                        android:id="@+id/itemsHeader"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="16dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <!-- Icon with background - matches HTML .detail-card-title i -->
                        <FrameLayout
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_card_title_icon">
                            
                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_box"
                                app:tint="@color/text_light"
                                android:contentDescription="@string/items" />
                        </FrameLayout>

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/orderItemCountText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:text="@string/items"
                            android:textColor="@color/text_light"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:id="@+id/headerDivider"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="16dp"
                        android:background="#1AFFFFFF"
                        app:layout_constraintTop_toBottomOf="@id/itemsHeader" />

                    <!-- Items RecyclerView -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/itemRecycler"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="8dp"
                        android:clipToPadding="false"
                        android:paddingHorizontal="16dp"
                        android:paddingBottom="8dp"
                        app:layout_constraintBottom_toTopOf="@id/summarySection"
                        app:layout_constraintTop_toBottomOf="@id/headerDivider" />

                    <!-- Order Summary Section - matches HTML .detail-summary -->
                    <!-- padding: 16px 0 0 0, border-top, margin-top: 16px -->
                    <LinearLayout
                        android:id="@+id/summarySection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingTop="16dp"
                        android:paddingBottom="20dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <!-- Top border - matches HTML border-top: 1px solid rgba(255,255,255,0.1) -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#1AFFFFFF"
                            android:layout_marginBottom="16dp" />

                        <!-- Subtotal Row - matches HTML .detail-summary-row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="8dp">
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/subtotal"
                                android:textColor="@color/text_muted"
                                android:textSize="14sp" />
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/subtotalValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$0.00"
                                android:textColor="@color/text_light"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <!-- Tax Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="8dp">
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/tax"
                                android:textColor="@color/text_muted"
                                android:textSize="14sp" />
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/taxValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$0.00"
                                android:textColor="@color/text_light"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <!-- Discount Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="8dp">
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/discount"
                                android:textColor="@color/text_muted"
                                android:textSize="14sp" />
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/discountValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-$0.00"
                                android:textColor="@color/text_light"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <!-- Total separator - matches HTML .detail-summary-row.total border-top -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#1AFFFFFF"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="12dp" />

                        <!-- Total Row - matches HTML .detail-summary-row.total -->
                        <!-- font-weight: 600, font-size: 16px -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/total"
                                android:textColor="@color/text_light"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/totalValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$0.00"
                                android:textColor="@color/text_light"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Right Column: Order Details & History - matches HTML .order-detail-sidebar -->
        <!-- width: 380px, gap: 20px -->
        <LinearLayout
            android:id="@+id/buttonMenu"
            android:layout_width="380dp"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Order Details Card - clickable to open order-level popup -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/orderDetailsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/glass_background"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/nav_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Card Header with Status Badges - matches HTML .detail-card-header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="16dp">

                        <!-- Icon with background - matches HTML .detail-card-title i -->
                        <FrameLayout
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_card_title_icon">
                            
                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_receipt"
                                app:tint="@color/text_light"
                                android:contentDescription="@string/order_details" />
                        </FrameLayout>

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:text="@string/order_details"
                            android:textColor="@color/text_light"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <!-- Status badges - matches HTML .detail-status-badge -->
                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/orderPlacedStatusValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/badge_background_open"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:text="@string/open"
                            android:textColor="@color/open_status_color"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textAllCaps="true" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/paymentStatusBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/badge_background_paid"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:text="@string/paid"
                            android:textColor="@color/paid_status_color"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textAllCaps="true" />
                    </LinearLayout>

                    <!-- Order-level Notes Section (#93 requirement) -->
                    <LinearLayout
                        android:id="@+id/orderNotesSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="12dp"
                        android:visibility="gone">
                        
                        <!-- Order Notes Pills Container -->
                        <com.google.android.flexbox.FlexboxLayout
                            android:id="@+id/orderNotesPillsContainer"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:flexWrap="wrap"
                            app:alignItems="center"
                            app:justifyContent="flex_start" />
                        
                        <!-- Add/Edit Order Note Button -->
                        <ImageView
                            android:id="@+id/btnAddOrderNote"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginStart="8dp"
                            android:src="@drawable/ic_edit"
                            android:padding="6dp"
                            android:background="@drawable/bg_filter_option"
                            app:tint="@color/order_dialog_accent"
                            android:contentDescription="@string/add_note"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="16dp"
                        android:background="#1AFFFFFF" />

                    <!-- #51: Order Info Rows - reduced padding -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp">

                        <!-- Order Date - matches HTML .detail-info-row -->
                        <!-- padding: 12px 0, border-bottom: 1px solid rgba(255,255,255,0.05) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="12dp">
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/order_date"
                                android:textColor="@color/text_muted"
                                android:textSize="13sp" />
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/orderPlacedAtValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_light"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                        
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#0DFFFFFF" />

                        <!-- Due Date -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="12dp">
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/due_date"
                                android:textColor="@color/text_muted"
                                android:textSize="13sp" />
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/dueDateValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_light"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                        
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#0DFFFFFF" />

                        <!-- Order Tags -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="12dp">
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/order_tags"
                                android:textColor="@color/text_muted"
                                android:textSize="13sp" />
                            <LinearLayout
                                android:id="@+id/tagsContainer"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal" />
                        </LinearLayout>
                        
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#0DFFFFFF" />

                        <!-- #46: Description Row (from order notes) -->
                        <LinearLayout
                            android:id="@+id/descriptionRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="12dp"
                            android:visibility="gone">
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/description"
                                android:textColor="@color/text_muted"
                                android:textSize="13sp" />
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/orderDescriptionValue"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2"
                                android:gravity="end"
                                android:textColor="@color/text_light"
                                android:textSize="14sp"
                                android:maxLines="2"
                                android:ellipsize="end" />
                        </LinearLayout>
                        
                        <View
                            android:id="@+id/descriptionDivider"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#0DFFFFFF"
                            android:visibility="gone" />

                        <!-- Employee -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="12dp">
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/employee"
                                android:textColor="@color/text_muted"
                                android:textSize="13sp" />
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/employeeValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_light"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                        
                    </LinearLayout>
                    
                    <!-- Hidden description field for backward compatibility -->
                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/descriptionValue"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Customer Card - separate card with just the customer button, no header -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/customerCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@color/glass_background"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/nav_border"
                app:strokeWidth="1dp">

                <!-- Customer Row - clickable to open customer dialog -->
                <LinearLayout
                    android:id="@+id/customerRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_clickable_row"
                    android:paddingVertical="16dp"
                    android:paddingHorizontal="20dp"
                    android:clickable="true"
                    android:focusable="true">
                    
                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/customer"
                        android:textColor="@color/text_muted"
                        android:textSize="13sp" />
                    
                    <!-- Customer avatar - pill-shaped for dynamic initials -->
                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/customerAvatar"
                        android:layout_width="wrap_content"
                        android:layout_height="24dp"
                        android:minWidth="24dp"
                        android:paddingHorizontal="6dp"
                        android:background="@drawable/bg_customer_avatar_inline"
                        android:gravity="center"
                        android:text="?"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                    
                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/orderPlacedCustomerValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:textColor="@color/text_light"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                    
                    <!-- Chevron icon -->
                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/text_muted"
                        android:contentDescription="@string/view_customer" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Order History Card - entire card clickable to open history popup -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/orderHistoryCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/glass_background"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/nav_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Card Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="16dp">

                        <!-- Icon with background -->
                        <FrameLayout
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_card_title_icon">
                            
                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_history"
                                app:tint="@color/text_light"
                                android:contentDescription="@string/order_history" />
                        </FrameLayout>

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:text="@string/order_history"
                            android:textColor="@color/text_light"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <!-- Chevron to indicate clickable -->
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/text_muted"
                            android:contentDescription="@string/view_all" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="16dp"
                        android:background="#1AFFFFFF" />

                    <!-- History Items Container - no scroll, just shows items -->
                    <LinearLayout
                        android:id="@+id/historyContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="12dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            
            <!-- Hidden views for backward compatibility -->
            <ScrollView
                android:id="@+id/historyScrollView"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
            <View
                android:id="@+id/historyFadeOverlay"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
            <LinearLayout
                android:id="@+id/historyScrollIndicator"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
            <LinearLayout
                android:id="@+id/viewAllHistoryButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- Progress Overlay -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/progressLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Hidden views for backward compatibility -->
    <LinearLayout
        android:id="@+id/orderData"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Hidden RecyclerViews (data still displayed in items list) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/transactionRecycler"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/refundRecycler"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/noTransactionText"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/orderPlacedCustomerNumberValue"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/orderPlacedCustomerEmailValue"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/orderPlacedEmployeeValue"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/discount"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
