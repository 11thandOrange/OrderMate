<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_purple"
    tools:context=".fragment.orderDetail.OrderDetailFragment">

    <!-- Top Header Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Back Button -->
        <ImageView
            android:id="@+id/backButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_button_header"
            android:padding="10dp"
            android:src="@drawable/ic_back"
            app:tint="@color/white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:contentDescription="@string/back" />

        <!-- Order ID Title -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/orderId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/dummy_heading_dashboard"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/backButton"
            app:layout_constraintStart_toEndOf="@id/backButton"
            app:layout_constraintTop_toTopOf="@id/backButton" />

        <!-- Action Buttons Container -->
        <LinearLayout
            android:id="@+id/actionButtonsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Add Payment Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/addPayment"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:backgroundTint="@color/paid_status_color"
                android:text="@string/add_payment"
                android:textSize="12sp"
                android:textColor="@color/white"
                app:cornerRadius="10dp"
                app:icon="@drawable/ic_cash"
                app:iconTint="@color/white"
                app:iconSize="16dp"
                app:iconPadding="4dp" />

            <!-- Re-Open Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/reOpenButton"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:text="@string/re_open"
                android:textSize="12sp"
                android:textColor="@color/white"
                app:cornerRadius="10dp"
                app:strokeColor="@color/white"
                app:strokeWidth="1dp"
                app:icon="@drawable/ic_refresh"
                app:iconTint="@color/white"
                app:iconSize="16dp"
                app:iconPadding="4dp" />

            <!-- Send Notification Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/sendNotificationButton"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:text="@string/send_notification"
                android:textSize="12sp"
                android:textColor="@color/orange_accent"
                app:cornerRadius="10dp"
                app:strokeColor="@color/orange_accent"
                app:strokeWidth="1dp"
                app:icon="@drawable/ic_notification"
                app:iconTint="@color/orange_accent"
                app:iconSize="16dp"
                app:iconPadding="4dp" />

            <!-- Delete Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/deleteButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:backgroundTint="@color/delete_red"
                android:text="@string/delete_order"
                android:textSize="12sp"
                android:textColor="@color/white"
                app:cornerRadius="10dp"
                app:icon="@drawable/ic_delete"
                app:iconTint="@color/white"
                app:iconSize="16dp"
                app:iconPadding="4dp" />
        </LinearLayout>

        <!-- Syncing Text -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/syncingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="@string/syncing"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/actionButtonsContainer"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Hidden views for backward compatibility -->
        <ImageView
            android:id="@+id/syncButton"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/merchantName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/reIssueReceiptButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Main Content Area -->
    <LinearLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="24dp"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:weightSum="10"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <!-- Left Column: Items Card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/orderDetails"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="6"
            android:layout_marginEnd="12dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/itemsCard"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardBackgroundColor="@color/glass_background"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- Card Header - matches HTML .detail-card-header -->
                    <LinearLayout
                        android:id="@+id/itemsHeader"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="16dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <!-- Icon with background - matches HTML .detail-card-title i -->
                        <FrameLayout
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_card_title_icon">
                            
                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_box"
                                app:tint="@color/text_light"
                                android:contentDescription="@string/items" />
                        </FrameLayout>

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/orderItemCountText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:text="@string/items"
                            android:textColor="@color/text_light"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:id="@+id/headerDivider"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="16dp"
                        android:background="#1AFFFFFF"
                        app:layout_constraintTop_toBottomOf="@id/itemsHeader" />

                    <!-- Items RecyclerView -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/itemRecycler"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="8dp"
                        android:clipToPadding="false"
                        android:paddingHorizontal="16dp"
                        android:paddingBottom="8dp"
                        app:layout_constraintBottom_toTopOf="@id/summarySection"
                        app:layout_constraintTop_toBottomOf="@id/headerDivider" />

                    <!-- Order Summary Section -->
                    <LinearLayout
                        android:id="@+id/summarySection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:background="#1A000000"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <!-- Subtotal Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/subtotal"
                                android:textColor="@color/text_muted"
                                android:textSize="14sp" />
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/subtotalValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$0.00"
                                android:textColor="@color/text_light"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <!-- Tax Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/tax"
                                android:textColor="@color/text_muted"
                                android:textSize="14sp" />
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/taxValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$0.00"
                                android:textColor="@color/text_light"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <!-- Discount Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/discount"
                                android:textColor="@color/text_muted"
                                android:textSize="14sp" />
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/discountValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-$0.00"
                                android:textColor="@color/paid_status_color"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#1AFFFFFF"
                            android:layout_marginBottom="12dp" />

                        <!-- Total Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/total"
                                android:textColor="@color/text_light"
                                android:textSize="18sp"
                                android:textStyle="bold" />
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/totalValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$0.00"
                                android:textColor="@color/text_light"
                                android:textSize="18sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Right Column: Order Details & History -->
        <LinearLayout
            android:id="@+id/buttonMenu"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="4"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <!-- Order Details Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/orderDetailsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/glass_background"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Card Header with Status Badges - matches HTML .detail-card-header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="16dp">

                        <!-- Icon with background - matches HTML .detail-card-title i -->
                        <FrameLayout
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_card_title_icon">
                            
                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_receipt"
                                app:tint="@color/text_light"
                                android:contentDescription="@string/order_details" />
                        </FrameLayout>

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:text="@string/order_details"
                            android:textColor="@color/text_light"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <!-- Status badges - matches HTML .detail-status-badge -->
                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/orderPlacedStatusValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/badge_background_open"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:text="@string/open"
                            android:textColor="@color/open_status_color"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textAllCaps="true" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/paymentStatusBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/badge_background_paid"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:text="@string/paid"
                            android:textColor="@color/paid_status_color"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textAllCaps="true" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="16dp"
                        android:background="#1AFFFFFF" />

                    <!-- Order Info Rows -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Order Date -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/order_date"
                                android:textColor="@color/text_muted"
                                android:textSize="14sp" />
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/orderPlacedAtValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_light"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <!-- Due Date -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/due_date"
                                android:textColor="@color/text_muted"
                                android:textSize="14sp" />
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/dueDateValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_light"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <!-- Order Tags -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/order_tags"
                                android:textColor="@color/text_muted"
                                android:textSize="14sp" />
                            <LinearLayout
                                android:id="@+id/tagsContainer"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal" />
                        </LinearLayout>

                        <!-- Description -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/description"
                                android:textColor="@color/text_muted"
                                android:textSize="14sp" />
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/descriptionValue"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="16dp"
                                android:textColor="@color/text_light"
                                android:textSize="14sp"
                                android:gravity="end" />
                        </LinearLayout>

                        <!-- Employee -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/employee"
                                android:textColor="@color/text_muted"
                                android:textSize="14sp" />
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/employeeValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_light"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <!-- Customer (Clickable) - matches HTML .detail-info-row.clickable -->
                        <LinearLayout
                            android:id="@+id/customerRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_clickable_row"
                            android:padding="12dp"
                            android:layout_marginHorizontal="-12dp"
                            android:layout_marginTop="4dp"
                            android:clickable="true"
                            android:focusable="true">
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/customer"
                                android:textColor="@color/text_muted"
                                android:textSize="13sp" />
                            
                            <!-- Customer inline avatar with initials -->
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/customerAvatar"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:background="@drawable/bg_customer_avatar_inline"
                                android:gravity="center"
                                android:text="ED"
                                android:textColor="@color/white"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                            
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/orderPlacedCustomerValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:textColor="@color/text_light"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                            
                            <!-- Chevron icon -->
                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:layout_marginStart="8dp"
                                android:src="@drawable/ic_chevron_right"
                                app:tint="@color/text_muted"
                                android:contentDescription="@string/view_customer" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Order History Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/orderHistoryCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/glass_background"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Card Header - matches HTML .detail-card-header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="16dp">

                        <!-- Icon with background - matches HTML .detail-card-title i -->
                        <FrameLayout
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_card_title_icon">
                            
                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_history"
                                app:tint="@color/text_light"
                                android:contentDescription="@string/order_history" />
                        </FrameLayout>

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:text="@string/order_history"
                            android:textColor="@color/text_light"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <!-- View All button with chevron - matches HTML .detail-card-action -->
                        <LinearLayout
                            android:id="@+id/viewAllHistoryButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_view_all_button"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:clickable="true"
                            android:focusable="true">
                            
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/view_all"
                                android:textColor="@color/text_light"
                                android:textSize="12sp" />
                            
                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:layout_marginStart="6dp"
                                android:src="@drawable/ic_chevron_right"
                                app:tint="@color/text_light"
                                android:contentDescription="@string/view_all" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="16dp"
                        android:background="#1AFFFFFF" />

                    <!-- History Items -->
                    <LinearLayout
                        android:id="@+id/historyContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_item_row"
                            android:padding="12dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_notification"
                                app:tint="@color/orange_accent"
                                android:contentDescription="@string/notification" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:orientation="vertical">

                                <com.google.android.material.textview.MaterialTextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/reminder_sent"
                                    android:textColor="@color/text_light"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <com.google.android.material.textview.MaterialTextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="@string/sample_date_time"
                                    android:textColor="@color/text_muted"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/sms_reminder_sent"
                            android:textColor="@color/text_muted"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </LinearLayout>

    <!-- Progress Overlay -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/progressLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Hidden views for backward compatibility -->
    <LinearLayout
        android:id="@+id/orderData"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Hidden RecyclerViews (data still displayed in items list) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/transactionRecycler"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/refundRecycler"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/noTransactionText"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/orderPlacedCustomerNumberValue"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/orderPlacedCustomerEmailValue"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/orderPlacedEmployeeValue"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/discount"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
