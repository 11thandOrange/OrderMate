<?xml version="1.0" encoding="utf-8"?>
<!-- Shared header for List Tab and Calendar Tab -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/sharedHeader"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/header_background"
    android:paddingHorizontal="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="8dp">

    <!-- Top Row: Search + Filter + Reset -->
    <LinearLayout
        android:id="@+id/headerTopRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Search Container -->
        <LinearLayout
            android:id="@+id/searchContainer"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_search_bar"
            android:paddingHorizontal="12dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search"
                app:tint="@color/text_muted"/>

            <EditText
                android:id="@+id/searchInput"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:hint="@string/search_orders"
                android:textColorHint="@color/text_muted"
                android:textColor="@color/text_light"
                android:textSize="14sp"
                android:background="@null"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:maxLines="1"/>

            <!-- Date Picker Icon -->
            <ImageView
                android:id="@+id/datePickerButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="4dp"
                android:src="@drawable/ic_calendar"
                app:tint="@color/text_muted"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Select date"/>

        </LinearLayout>

        <!-- Filter Button -->
        <LinearLayout
            android:id="@+id/filterButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_header_button"
            android:paddingHorizontal="16dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_filter"
                app:tint="@color/text_light"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@string/filters"
                android:textColor="@color/text_light"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- Reset Button -->
        <LinearLayout
            android:id="@+id/resetButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_header_button_outline"
            android:paddingHorizontal="16dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_refresh"
                app:tint="@color/text_muted"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@string/reset"
                android:textColor="@color/text_muted"
                android:textSize="14sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Search Query Pill (shown when searching) -->
    <LinearLayout
        android:id="@+id/searchPillContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerTopRow">

        <LinearLayout
            android:id="@+id/searchPill"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:background="@drawable/bg_filter_pill">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/searchPillText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text=""
                android:textColor="@color/text_light"
                android:textSize="13sp"
                android:maxWidth="150dp"
                android:ellipsize="end"
                android:maxLines="1"/>

            <ImageView
                android:id="@+id/searchPillClose"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_close"
                app:tint="@color/text_muted"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Filter Pills Scroll -->
    <HorizontalScrollView
        android:id="@+id/filterPillsScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:scrollbars="none"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/searchPillContainer">

        <LinearLayout
            android:id="@+id/filterPillsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"/>
    </HorizontalScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
