<?xml version="1.0" encoding="utf-8"?>
<!-- Filter Dialog (#80 requirement) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog"
    android:padding="24dp">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Filter Orders"
        android:textColor="@color/text_light"
        android:textSize="20sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="24dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Payment Status Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PAYMENT STATUS"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="10dp"/>

                <com.google.android.flexbox.FlexboxLayout
                    android:id="@+id/paymentStatusOptions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:flexWrap="wrap"
                    app:alignItems="flex_start"
                    app:flexDirection="row"/>
            </LinearLayout>

            <!-- Order Status Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ORDER STATUS"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="10dp"/>

                <com.google.android.flexbox.FlexboxLayout
                    android:id="@+id/orderStatusOptions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:flexWrap="wrap"
                    app:alignItems="flex_start"
                    app:flexDirection="row"/>
            </LinearLayout>

            <!-- Payment Type Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PAYMENT TYPE"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="10dp"/>

                <com.google.android.flexbox.FlexboxLayout
                    android:id="@+id/paymentTypeOptions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:flexWrap="wrap"
                    app:alignItems="flex_start"
                    app:flexDirection="row"/>
            </LinearLayout>

            <!-- Booking Type Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BOOKING TYPE"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="10dp"/>

                <com.google.android.flexbox.FlexboxLayout
                    android:id="@+id/bookingTypeOptions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:flexWrap="wrap"
                    app:alignItems="flex_start"
                    app:flexDirection="row"/>
            </LinearLayout>

            <!-- Employee Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EMPLOYEE"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="10dp"/>

                <com.google.android.flexbox.FlexboxLayout
                    android:id="@+id/employeeOptions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:flexWrap="wrap"
                    app:alignItems="flex_start"
                    app:flexDirection="row"/>
            </LinearLayout>

            <!-- Notes Category Section -->
            <LinearLayout
                android:id="@+id/notesCategorySection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CATEGORY"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="10dp"/>

                <com.google.android.flexbox.FlexboxLayout
                    android:id="@+id/categoryOptions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:flexWrap="wrap"
                    app:alignItems="flex_start"
                    app:flexDirection="row"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="24dp">

        <TextView
            android:id="@+id/btnClearAll"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:paddingHorizontal="20dp"
            android:text="Clear All"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <TextView
            android:id="@+id/btnApply"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:layout_marginStart="16dp"
            android:text="Apply Filters"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_button_orange"/>
    </LinearLayout>

</LinearLayout>
