<?xml version="1.0" encoding="utf-8"?>
<!-- Note pill for order detail items (#87 requirement) -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="8dp"
    android:paddingVertical="3dp"
    android:layout_marginEnd="6dp"
    android:layout_marginBottom="4dp"
    android:background="@drawable/bg_pill_neutral">

    <!-- Icon container with background (#77) - matches Settings tab styling -->
    <FrameLayout
        android:id="@+id/pillIconContainer"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginEnd="6dp"
        android:background="@drawable/bg_widget_icon_calendar">

        <ImageView
            android:id="@+id/pillIcon"
            android:layout_width="11dp"
            android:layout_height="11dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_label"
            app:tint="@color/text_light"/>

    </FrameLayout>

    <TextView
        android:id="@+id/pillText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="@color/text_light"
        tools:text="Custom Cake"/>

</LinearLayout>
