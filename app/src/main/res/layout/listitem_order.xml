<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="1dp">

    <View
        android:id="@+id/orderItemColor"
        android:layout_width="@dimen/_3sdp"
        android:layout_height="0dp"
        android:background="@color/black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/orderItemName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/_10sdp"
        android:ellipsize="end"
        android:maxWidth="@dimen/_100sdp"
        android:maxLines="2"
        android:paddingTop="@dimen/_3sdp"
        android:paddingBottom="@dimen/_1sdp"
        android:text="@string/dummy_time"
        android:textSize="@dimen/_8sdp"
        android:textStyle="bold"
        app:layout_constraintHorizontal_chainStyle="spread"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/orderItemQuantity"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxWidth="@dimen/_100sdp"
        android:maxLines="1"
        android:paddingBottom="@dimen/_1sdp"
        android:visibility="gone"
        android:textSize="@dimen/_6sdp"
        android:textColor="@color/darker_gray"
        app:layout_constraintHorizontal_chainStyle="spread"
        app:layout_constraintStart_toStartOf="@id/orderItemName"
        app:layout_constraintTop_toBottomOf="@id/orderItemName" />


    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/orderPrice"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_marginEnd="16dp"
        android:maxWidth="@dimen/_30sdp"
        android:maxLines="1"
        android:paddingVertical="@dimen/_3sdp"
        android:text="@string/dummy_id"
        android:textAlignment="textStart"
        android:textColor="#2c3a3f"
        android:textSize="@dimen/_8sdp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/addNotesButton"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/editNote"
        android:layout_width="@dimen/_20sdp"
        android:layout_height="@dimen/_20sdp"
        android:layout_marginHorizontal="@dimen/_5sdp"
        android:src="@drawable/ic_edit"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/addNotesButton"
        android:layout_width="@dimen/_15sdp"
        android:layout_height="@dimen/_15sdp"
        android:layout_marginHorizontal="@dimen/_5sdp"
        android:src="@drawable/ic_add"
        android:paddingTop="@dimen/_1sdp"
        app:layout_constraintEnd_toStartOf="@id/editNote"
        app:layout_constraintTop_toTopOf="parent" />


    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/orderItemCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/_2sdp"
        android:ellipsize="end"
        android:ems="5"
        android:maxWidth="@dimen/_100sdp"
        android:paddingVertical="@dimen/_3sdp"
        android:text="@string/dummy_date"
        android:textColor="@color/black"
        android:textSize="@dimen/_8ssp"
        android:visibility="visible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.7"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/orderNotes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/_5sdp"
        android:ellipsize="end"
        android:maxWidth="@dimen/_100sdp"
        android:maxLines="10"
        android:paddingTop="@dimen/_3sdp"
        android:paddingBottom="@dimen/_1sdp"
        android:visibility="gone"
        android:text="@string/dummy_time"
        android:textSize="@dimen/_8sdp"
        android:textColor="@color/darker_gray"
        android:layout_marginVertical="@dimen/_1sdp"
        app:layout_constraintHorizontal_chainStyle="spread"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/orderItemQuantity" />
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/subItemRecycler"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/orderItemColor"
        app:layout_constraintTop_toBottomOf="@id/orderNotes" />

    <com.google.android.material.divider.MaterialDivider
        android:layout_width="match_parent"
        android:layout_height="1.5dp"
        app:dividerColor="#e1e1e1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>