<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center_horizontal"
    android:background="@color/white">


    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/menuItemType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxWidth="@dimen/_300sdp"
        android:paddingHorizontal="@dimen/_10sdp"
        android:paddingVertical="@dimen/_6sdp"
        android:text="@string/category"
        android:textColor="#2c3a3f"
        android:textSize="@dimen/_8sdp"
        app:layout_constraintBottom_toBottomOf="@id/menuEnableButton"
        app:layout_constraintHorizontal_chainStyle="spread"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/menuEnableButton" />


    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/menuEnableButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/_10sdp"
        android:layout_marginVertical="@dimen/_1sdp"
        android:shadowColor="@color/darker_gray"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:thumbIconTint="@color/darker_gray"
        app:trackTint="@drawable/switch_thumb_states" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/arrowDown"
        android:layout_width="@dimen/_20sdp"
        android:layout_height="@dimen/_16sdp"
        android:src="@drawable/ic_up_arrow"
        app:layout_constraintBottom_toBottomOf="@id/menuEnableButton"
        app:layout_constraintEnd_toStartOf="@id/menuEnableButton"
        app:layout_constraintTop_toTopOf="@id/menuEnableButton" />



    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/addItemLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:weightSum="1"
        android:visibility="gone"
        android:paddingHorizontal="@dimen/_5sdp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/menuEnableButton">

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/addItems"
            android:layout_width="wrap_content"
            android:hint="@string/enter_value"
            android:textSize="@dimen/_8ssp"
            android:padding="@dimen/_4sdp"
            android:minHeight="@dimen/_10sdp"
            android:maxWidth="@dimen/_300sdp"
            android:minWidth="@dimen/_100sdp"
            android:maxLines="1"
            android:maxLength="20"
            android:inputType="text"
            android:imeOptions="actionNext"
            android:singleLine="true"
            android:layout_marginHorizontal="@dimen/_5sdp"
            android:background="@drawable/custom_fields_border"
            android:layout_height="wrap_content"/>

        <ImageView
            android:id="@+id/addMoreItemsButton"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/_15sdp"
            android:src="@drawable/ic_add"
            android:layout_marginVertical="@dimen/_2sdp"
            app:layout_constraintTop_toTopOf="@id/addItems"
            app:layout_constraintBottom_toBottomOf="@id/addItems"
            app:layout_constraintEnd_toStartOf="@id/arrowDown"
            />

    </androidx.appcompat.widget.LinearLayoutCompat>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/menuItemValueRecycler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/_5sdp"
        android:layout_marginVertical="@dimen/_3sdp"
        android:visibility="gone"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:layout_constraintBottom_toTopOf="@+id/bottomDivider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/addItemLayout" />

    <com.google.android.material.divider.MaterialDivider
        android:id="@+id/bottomDivider"
        android:layout_width="match_parent"
        android:layout_height="1.5dp"
        app:dividerColor="#e1e1e1"
        android:layout_marginTop="@dimen/_3sdp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>