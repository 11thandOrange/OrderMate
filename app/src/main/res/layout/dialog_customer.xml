<?xml version="1.0" encoding="utf-8"?>
<!-- Customer Dialog - matches HTML .customer-modal-content with filter modal styling -->
<!-- background: gradient, border-radius: 20px -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="400dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog">

    <!-- Header - matches HTML .customer-modal-header -->
    <!-- padding: 20px, border-bottom: 1px solid rgba(255,255,255,0.1) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/dialogTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/customer_details"
            android:textColor="@color/text_light"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Close button - matches HTML .customer-modal-close -->
        <!-- 32x32, border-radius: 8px, background: rgba(255,255,255,0.1) -->
        <ImageView
            android:id="@+id/closeButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_dialog_close_button"
            android:padding="8dp"
            android:src="@drawable/ic_close"
            app:tint="@color/text_light"
            android:contentDescription="@string/cancel" />
    </LinearLayout>

    <!-- Header border -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/nav_border" />

    <!-- Body - matches HTML .customer-modal-body -->
    <!-- padding: 24px -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Customer Avatar and Name - matches HTML .customer-view-header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <!-- Avatar - 70x70, orange background -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/customerAvatar"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:background="@drawable/bg_customer_avatar_large"
                android:gravity="center"
                android:text="ED"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/customerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Emily Davis"
                android:textColor="@color/text_light"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Customer Details - matches HTML .customer-view-details -->
        <!-- gap: 12px -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Phone Row - matches HTML .customer-view-row -->
            <!-- padding: 12px 16px, background: rgba(0,0,0,0.2), border-radius: 10px -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_modal_info_row"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_phone"
                    app:tint="@color/text_muted"
                    android:contentDescription="@string/customer_number" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/customerPhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="(555) 234-5678"
                    android:textColor="@color/text_light"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Email Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_modal_info_row"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_email"
                    app:tint="@color/text_muted"
                    android:contentDescription="@string/email" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/customerEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="emily.davis@email.com"
                    android:textColor="@color/text_light"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Notes Row -->
            <LinearLayout
                android:id="@+id/notesRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_modal_info_row"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_notes"
                    app:tint="@color/text_muted"
                    android:contentDescription="@string/notes" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/customerNotes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Prefers text messages"
                    android:textColor="@color/text_light"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Footer border -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/nav_border" />

    <!-- Footer - matches HTML .customer-modal-footer -->
    <!-- padding: 16px 24px, gap: 12px -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp"
        android:gravity="end">

        <!-- Close button - matches HTML .customer-modal-btn.cancel -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClose"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginEnd="12dp"
            android:backgroundTint="@color/glass_background"
            android:text="@string/close"
            android:textColor="@color/text_light"
            android:textSize="14sp"
            android:paddingHorizontal="20dp"
            app:cornerRadius="12dp" />

        <!-- Edit button - matches HTML .customer-modal-btn.save -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEdit"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:backgroundTint="@color/orange_accent"
            android:text="@string/edit"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:paddingHorizontal="20dp"
            app:cornerRadius="12dp" />
    </LinearLayout>
</LinearLayout>
