<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/dialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Date &amp; Time"
            android:textColor="@color/text_light"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/dialogSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            tools:text="Due Date" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/nav_border" />

    <!-- Body - Side by side layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Date Section -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DATE"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/glass_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- Calendar Navigation -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:id="@+id/btnPrevMonth"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_chevron_left"
                            android:padding="6dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Previous month"
                            app:tint="@color/text_primary"
                            xmlns:app="http://schemas.android.com/apk/res-auto" />

                        <TextView
                            android:id="@+id/monthYearText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:textColor="@color/text_light"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            tools:text="April 2026" />

                        <ImageView
                            android:id="@+id/btnNextMonth"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_chevron_right"
                            android:padding="6dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Next month"
                            app:tint="@color/text_primary"
                            xmlns:app="http://schemas.android.com/apk/res-auto" />

                    </LinearLayout>

                    <!-- Day Headers -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Su" android:gravity="center" android:textColor="@color/text_muted" android:textSize="10sp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Mo" android:gravity="center" android:textColor="@color/text_muted" android:textSize="10sp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Tu" android:gravity="center" android:textColor="@color/text_muted" android:textSize="10sp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="We" android:gravity="center" android:textColor="@color/text_muted" android:textSize="10sp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Th" android:gravity="center" android:textColor="@color/text_muted" android:textSize="10sp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Fr" android:gravity="center" android:textColor="@color/text_muted" android:textSize="10sp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Sa" android:gravity="center" android:textColor="@color/text_muted" android:textSize="10sp" />

                    </LinearLayout>

                    <!-- Calendar Grid (RecyclerView with GridLayoutManager) -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/calendarGrid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:overScrollMode="never" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Time Section (#77: Combination lock style scroll) -->
        <LinearLayout
            android:layout_width="140dp"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TIME"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/glass_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">

                    <!-- Hour and Minute with combination lock style scroll -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <!-- Hour Column - Combination Lock Style -->
                        <LinearLayout
                            android:id="@+id/hourScrollContainer"
                            android:layout_width="44dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center">

                            <!-- Previous hour (faded) -->
                            <TextView
                                android:id="@+id/hourPrevText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="16sp"
                                android:textColor="@color/text_muted"
                                android:alpha="0.4"
                                android:gravity="center"
                                tools:text="01" />

                            <!-- Current hour (highlighted) -->
                            <TextView
                                android:id="@+id/hourText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_light"
                                android:gravity="center"
                                android:paddingVertical="4dp"
                                tools:text="02" />

                            <!-- Next hour (faded) -->
                            <TextView
                                android:id="@+id/hourNextText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="16sp"
                                android:textColor="@color/text_muted"
                                android:alpha="0.4"
                                android:gravity="center"
                                tools:text="03" />

                        </LinearLayout>

                        <!-- Colon separator -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_muted"
                            android:layout_marginHorizontal="4dp" />

                        <!-- Minute Column - Combination Lock Style -->
                        <LinearLayout
                            android:id="@+id/minuteScrollContainer"
                            android:layout_width="44dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center">

                            <!-- Previous minute (faded) -->
                            <TextView
                                android:id="@+id/minutePrevText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="16sp"
                                android:textColor="@color/text_muted"
                                android:alpha="0.4"
                                android:gravity="center"
                                tools:text="29" />

                            <!-- Current minute (highlighted) -->
                            <TextView
                                android:id="@+id/minuteText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_light"
                                android:gravity="center"
                                android:paddingVertical="4dp"
                                tools:text="30" />

                            <!-- Next minute (faded) -->
                            <TextView
                                android:id="@+id/minuteNextText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="16sp"
                                android:textColor="@color/text_muted"
                                android:alpha="0.4"
                                android:gravity="center"
                                tools:text="31" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- (#77) AM/PM as separate rows -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="12dp">

                        <TextView
                            android:id="@+id/btnAM"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="AM"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:paddingVertical="10dp"
                            android:gravity="center"
                            android:background="@drawable/bg_period_button"
                            android:textColor="@color/text_muted" />

                        <TextView
                            android:id="@+id/btnPM"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="PM"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:paddingVertical="10dp"
                            android:gravity="center"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/bg_period_button_selected"
                            android:textColor="@color/white" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/nav_border" />

    <!-- Footer - matching order/item note dialog style -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginEnd="12dp"
            android:backgroundTint="@color/glass_background"
            android:text="Cancel"
            android:textColor="@color/text_light"
            android:textSize="14sp"
            android:paddingHorizontal="16dp"
            app:cornerRadius="12dp"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:backgroundTint="@color/orange_accent"
            android:text="Save"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:paddingHorizontal="20dp"
            app:cornerRadius="12dp"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

    </LinearLayout>

</LinearLayout>
