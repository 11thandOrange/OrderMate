<?xml version="1.0" encoding="utf-8"?>
<!-- Send Notification Dialog - matches filter modal styling -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="520dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog">

    <!-- Header - matches HTML .modal-header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="24dp">

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/send_notification"
            android:textColor="@color/text_light"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Header border -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/nav_border" />

    <!-- Body -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Tab Selector (SMS / Email) - matches HTML .filter-options -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/shareSms"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_filter_option_selected"
                android:paddingVertical="12dp"
                android:text="@string/sms"
                android:textAlignment="center"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/shareEmail"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_filter_option"
                android:paddingVertical="12dp"
                android:text="@string/email"
                android:textAlignment="center"
                android:textColor="@color/text_light"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Template Dropdown Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/template"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_modal_input">

                <Spinner
                    android:id="@+id/templateSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:paddingStart="16dp"
                    android:paddingEnd="40dp"
                    android:popupBackground="@drawable/bg_dialog"
                    android:spinnerMode="dropdown"
                    android:clickable="true"
                    android:focusable="true" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_arrow_down"
                    app:tint="@color/text_muted"
                    android:importantForAccessibility="no"
                    android:clickable="false"
                    android:focusable="false" />
            </FrameLayout>
        </LinearLayout>

        <!-- Customer Number/Email Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/customerEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/customer_number"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />

            <LinearLayout
                android:id="@+id/llEditTex"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_modal_input"
                android:paddingHorizontal="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/customerNumber"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@null"
                    android:inputType="phone"
                    android:hint="@string/enter_the_customer_number"
                    android:textColor="@color/text_light"
                    android:textColorHint="@color/text_muted"
                    android:textSize="14sp"
                    android:focusable="true"
                    android:focusableInTouchMode="true" />
            </LinearLayout>
        </LinearLayout>

        <!-- Subject Section (Email only) -->
        <LinearLayout
            android:id="@+id/subjectContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/emailSubject"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/subject"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />

            <LinearLayout
                android:id="@+id/llSubject"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_modal_input"
                android:paddingHorizontal="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/subject"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@null"
                    android:singleLine="true"
                    android:maxLength="100"
                    android:hint="@string/enter_the_subject"
                    android:textColor="@color/text_light"
                    android:textColorHint="@color/text_muted"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Message Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/emailData"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/message"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />

            <LinearLayout
                android:id="@+id/llNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_modal_input"
                android:padding="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNotes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="@string/enter_your_notes_here"
                    android:minLines="4"
                    android:inputType="textMultiLine"
                    android:maxLength="250"
                    android:textColor="@color/text_light"
                    android:textColorHint="@color/text_muted"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Hidden TextInputLayout for compatibility -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/etNotesParent"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- Footer border -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/nav_border" />

    <!-- Footer buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cancelButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginEnd="12dp"
            android:backgroundTint="@color/glass_background"
            android:text="@string/cancel"
            android:textColor="@color/text_light"
            android:textSize="14sp"
            android:paddingHorizontal="20dp"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/sendButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:backgroundTint="@color/orange_accent"
            android:text="@string/send"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:paddingHorizontal="20dp"
            app:cornerRadius="12dp" />
    </LinearLayout>
</LinearLayout>