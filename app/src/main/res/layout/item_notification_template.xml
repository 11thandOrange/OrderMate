<?xml version="1.0" encoding="utf-8"?>
<!-- Notification Template Item Layout -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_template_item"
    android:orientation="vertical">

    <!-- Template Header (always visible) -->
    <LinearLayout
        android:id="@+id/templateHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Template Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/templateName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_light"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="Order Ready" />

            <TextView
                android:id="@+id/templatePreview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                tools:text="Your order from {{merchant_name}} is ready..." />

        </LinearLayout>

        <!-- Expand Chevron -->
        <ImageView
            android:id="@+id/expandChevron"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_chevron_down"
            app:tint="@color/text_muted" />

    </LinearLayout>

    <!-- Template Body (expandable) -->
    <LinearLayout
        android:id="@+id/templateBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp"
        android:visibility="gone">

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="12dp"
            android:background="#1AFFFFFF" />

        <!-- Template Name Input -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Template Name"
            android:textColor="@color/text_muted"
            android:textSize="11sp" />

        <EditText
            android:id="@+id/inputTemplateName"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_settings_input"
            android:hint="Enter name"
            android:paddingHorizontal="12dp"
            android:textColor="@color/text_light"
            android:textColorHint="@color/text_muted"
            android:textSize="13sp" />

        <!-- #64: Email Subject Line -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Email Subject (optional)"
            android:textColor="@color/text_muted"
            android:textSize="11sp" />

        <EditText
            android:id="@+id/inputTemplateSubject"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_settings_input"
            android:hint="Enter email subject line"
            android:paddingHorizontal="12dp"
            android:textColor="@color/text_light"
            android:textColorHint="@color/text_muted"
            android:textSize="13sp"
            android:inputType="text"
            android:maxLines="1" />

        <!-- Template Content -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Message Content"
            android:textColor="@color/text_muted"
            android:textSize="11sp" />

        <EditText
            android:id="@+id/inputTemplateContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_settings_input"
            android:gravity="top|start"
            android:hint="Enter message template..."
            android:inputType="textMultiLine"
            android:maxLength="250"
            android:minLines="3"
            android:padding="12dp"
            android:textColor="@color/text_light"
            android:textColorHint="@color/text_muted"
            android:textSize="13sp" />
        
        <!-- Template Variables Help -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Variables: {{merchant_name}}, {{order_id}}, {{customer_name}}, {{due_date}}, {{due_time}}, {{order_total}}"
            android:textColor="#80FFFFFF"
            android:textSize="10sp"
            android:lineSpacingExtra="2dp" />

        <!-- Footer with char count and delete -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/charCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                tools:text="52/250" />

            <ImageView
                android:id="@+id/btnDeleteTemplate"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="6dp"
                android:src="@drawable/ic_delete"
                app:tint="#EF4444" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
