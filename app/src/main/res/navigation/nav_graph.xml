<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/orderHistoryFragment">

    <fragment
        android:id="@+id/customFieldsFragment"
        android:name="com.specialOrder.fragment.customFields.CustomFieldsFragment"
        android:label="fragment_custom_fields"
        tools:layout="@layout/fragment_custom_fields">
        <action
            android:id="@+id/action_customFieldsFragment_to_orderHistoryFragment"
            app:destination="@id/orderHistoryFragment"
            app:launchSingleTop="true"
            app:popUpTo="@id/customFieldsFragment"
            app:popUpToInclusive="true" />
    </fragment>
    <fragment
        android:id="@+id/orderHistoryFragment"
        android:name="com.specialOrder.fragment.orderHistory.OrderHistoryFragment"
        android:label="fragment_order_history"
        tools:layout="@layout/fragment_order_history">
        <action
            android:id="@+id/action_orderHistoryFragment_to_customFieldsFragment"
            app:destination="@id/customFieldsFragment" />
        <action
            android:id="@+id/action_orderHistoryFragment_to_orderDetailFragment"
            app:destination="@id/orderDetailFragment"
            app:launchSingleTop="true" />
    </fragment>
    <fragment
        android:id="@+id/orderDetailFragment"
        android:name="com.specialOrder.fragment.orderDetail.OrderDetailFragment"
        android:label="fragment_order_detail"
        tools:layout="@layout/fragment_order_detail">
        <action
            android:id="@+id/action_orderDetailFragment_to_orderHistoryFragment"
            app:destination="@id/orderHistoryFragment"
            app:launchSingleTop="true"
            app:popUpTo="@id/orderHistoryFragment"
            app:popUpToInclusive="false" />
        <argument
            android:name="orderData"
            app:argType="com.clover.sdk.v3.order.Order" />

    </fragment>

</navigation>