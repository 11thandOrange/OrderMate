<?xml version="1.0" encoding="utf-8"?>
<!-- Calendar day background (#25: Added grid lines) -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_background_hover"/>
            <stroke android:width="1dp" android:color="@color/orange_accent"/>
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_background"/>
            <stroke android:width="1dp" android:color="@color/calendar_grid_line"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent"/>
            <!-- #25: Grid lines - 10% white border for day separation -->
            <stroke android:width="1dp" android:color="@color/calendar_grid_line"/>
        </shape>
    </item>
</selector>
