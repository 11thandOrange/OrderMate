<?xml version="1.0" encoding="utf-8"?>
<!-- Glassmorphism background for event preview (matches HTML .event-preview-content) -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/event_preview_bg"/>
    <stroke 
        android:width="1dp"
        android:color="@color/event_preview_border"/>
    <corners android:radius="20dp"/>
</shape>
