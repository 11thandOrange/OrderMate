<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="orderListStyle">
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:ellipsize">end</item>
        <item name="maxLines">2</item>
        <item name="android:paddingTop">@dimen/_2sdp</item>
        <item name="android:textSize">@dimen/_8ssp</item>
    </style>


    <style name="AlertDialogTheme" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="alertDialogStyle">@style/MyAlertDialogStyle</item>
    </style>

    <style name="MyAlertDialogStyle" parent="MaterialAlertDialog.MaterialComponents">
        <item name="iconSize">50dp</item>
        <item name="startIconMinSize">50dp</item>
    </style>
    <!-- Date picker theme (#13) - orange accent for selection, theme color for header applied programmatically -->
    <style name="MyDatePickerDialogTheme" parent="Theme.AppCompat.DayNight.Dialog">
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColor">@color/white</item>
        <item name="subheaderColor">@color/white</item>
        <item name="android:negativeButtonText">Clear</item>
        <!-- Orange accent for selected date circle (#13) -->
        <item name="colorAccent">@color/orange_accent</item>
        <item name="android:colorAccent">@color/orange_accent</item>
    </style>


    <style name="AppTheme.Dialog" parent="Theme.Material3.Light.Dialog">
        <!-- Customize your theme here -->
        <item name="android:windowMinWidthMajor">90%</item>
        <item name="android:windowMinWidthMinor">90%</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
    </style>

    <style name="orderListStyleHeader">
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:ellipsize">end</item>
        <item name="maxLines">2</item>
        <item name="android:paddingTop">@dimen/_1sdp</item>
        <item name="android:paddingBottom">3dp</item>
        <item name="android:textSize">@dimen/_8ssp</item>
    </style>

    <!-- iOS-style redesign styles (#80 requirement) -->
    <style name="GlassCard">
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="GlassButton">
        <item name="android:background">@drawable/bg_glass_button</item>
        <item name="android:textColor">@color/text_light</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="StatusBadge">
        <item name="android:paddingHorizontal">10dp</item>
        <item name="android:paddingVertical">4dp</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="StatusBadge.Open">
        <item name="android:background">@drawable/bg_badge_open</item>
        <item name="android:textColor">@color/open_status_color</item>
    </style>

    <style name="StatusBadge.Paid">
        <item name="android:background">@drawable/bg_badge_paid</item>
        <item name="android:textColor">@color/paid_status_color</item>
    </style>

    <style name="StatusBadge.Unpaid">
        <item name="android:background">@drawable/bg_badge_unpaid</item>
        <item name="android:textColor">@color/unpaid_status_color</item>
    </style>

    <style name="StatusBadge.Closed">
        <item name="android:background">@drawable/bg_badge_closed</item>
        <item name="android:textColor">@color/closed_status_color</item>
    </style>

    <!-- Base style for NotePill -->
    <style name="NotePill">
        <item name="android:paddingHorizontal">8dp</item>
        <item name="android:paddingVertical">2dp</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="NotePill.Category">
        <item name="android:background">@drawable/bg_note_chip_category</item>
        <item name="android:textColor">@color/tag_category_text</item>
        <item name="android:paddingHorizontal">8dp</item>
        <item name="android:paddingVertical">2dp</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="NotePill.Tag">
        <item name="android:background">@drawable/bg_note_chip_tag</item>
        <item name="android:textColor">@color/tag_pill_text</item>
        <item name="android:paddingHorizontal">8dp</item>
        <item name="android:paddingVertical">2dp</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Base style for ActionButton -->
    <style name="ActionButton">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="ActionButton.Orange">
        <item name="android:background">@drawable/bg_button_orange</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="ActionButton.Delete">
        <item name="android:background">@drawable/bg_button_delete</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>

</resources>