<?xml version="1.0" encoding="utf-8"?>
<!-- Dialog background - glassmorphism style matching HTML filter modal -->
<!-- Uses semi-transparent dark to simulate backdrop-filter effect -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#CC292D3E"/>
    <corners android:radius="20dp"/>
    <stroke
        android:width="1dp"
        android:color="#1AFFFFFF"/>
</shape>
