<?xml version="1.0" encoding="utf-8"?>
<!-- Calendar day item (#82 requirement) -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="100dp">

    <LinearLayout
        android:id="@+id/dayContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="@drawable/bg_calendar_day"
        android:clickable="true"
        android:focusable="true">

        <!-- Day Number -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            
            <TextView
                android:id="@+id/dayNumber"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:textColor="@color/text_light"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                tools:text="15"/>
        </FrameLayout>

        <!-- Events Container -->
        <LinearLayout
            android:id="@+id/eventsContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            tools:visibility="visible">

            <!-- Event 1 -->
            <TextView
                android:id="@+id/event1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="6dp"
                android:paddingVertical="3dp"
                android:layout_marginBottom="2dp"
                android:background="@drawable/bg_calendar_event_pickup"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/event_pickup"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:visibility="gone"
                tools:text="Sarah J."
                tools:visibility="visible"/>

            <!-- Event 2 -->
            <TextView
                android:id="@+id/event2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="6dp"
                android:paddingVertical="3dp"
                android:layout_marginBottom="2dp"
                android:background="@drawable/bg_calendar_event_delivery"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/event_delivery"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:visibility="gone"
                tools:text="John D."
                tools:visibility="visible"/>

            <!-- More Events Indicator -->
            <TextView
                android:id="@+id/moreEvents"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_muted"
                android:textSize="9sp"
                android:visibility="gone"
                tools:text="+2 more"
                tools:visibility="visible"/>

        </LinearLayout>

        <!-- Single Event Indicator (small dot for compact view) -->
        <View
            android:id="@+id/eventIndicator"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_event_dot"
            android:visibility="gone"/>

    </LinearLayout>

</FrameLayout>
